[Desktop Entry]
Name=KeePassXC
Comment=Launch KeePassXC (installs via Flatpak if missing)
Exec=$HOME/.config/sumika-shell/scripts/keepassxc
Icon=$HOME/.config/sumika-shell/launchers/icons/keepassxc.png
Terminal=false
Type=Application
Categories=Utility;Security;
X-FlatpakAppId=org.keepassxc.KeePassXC
